{
  "name": "oyl",
  "description": "Organize Your Life",
  "version": "1.0.0",
  "author": "Steve Hynding",
  "scripts": {
    "all-of": "pnpm --filter @oyl/all-of-oyl",
    "e2e": "pnpm --filter @oyl/e2e-oyl",
    "next": "pnpm --filter @oyl/next-oyl",
    "react": "pnpm --filter @oyl/react-oyl",
    "storybook": "pnpm --filter @oyl/storybook-oyl",
    "strapi": "pnpm --filter @oyl/strapi-oyl",
    "vanilla": "pnpm --filter @oyl/vanilla-oyl",
    "test": "pnpm --filter './packages/*' --if-present test",
    "lint": "pnpm --filter './packages/*' --if-present lint",
    "typecheck": "pnpm --filter './packages/*' --if-present typecheck",
    "verify:up": "docker compose -f docker-compose.verify.yml --project-name oyl-verify up -d --build --wait",
    "verify:seed": "E2E_STRAPI_PORT=13337 pnpm --filter @oyl/e2e-oyl seed",
    "verify:down": "docker compose -f docker-compose.verify.yml --project-name oyl-verify down -v",
    "verify": "pnpm verify:up && pnpm verify:seed"
  },
  "dependencies": {
    "prettier": "^3.6.2"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "pnpm": ">=10.6.1"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "farmhash",
      "sharp",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "core-js-pure"
    ],
    "supportedArchitectures": {
      "os": ["current", "linux"],
      "cpu": ["current", "arm64"],
      "libc": ["current", "musl"]
    }
  }
}
