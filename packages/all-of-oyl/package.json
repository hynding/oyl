{
  "name": "@oyl/all-of-oyl",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "description": "Core package for all of OYL",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./modules": "./modules/index.ts",
    "./modules/*": "./modules/*",
    "./vendors/*": "./vendors/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate-module": "ts-node packages/all-of-oyl/scripts/generate-module.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:src": "tsc -p src --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "rrule": "^2.8.1"
  }
}