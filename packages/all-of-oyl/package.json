{
  "name": "@oyl/all-of-oyl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Core package for all of OYL",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./format": "./src/format/index.ts",
    "./testing": "./src/core/http-repository-contract.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:src": "tsc -p src --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/check-no-bare-imports.mjs",
    "build:clean": "rm -rf dist && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "rrule": "^2.8.1"
  }
}