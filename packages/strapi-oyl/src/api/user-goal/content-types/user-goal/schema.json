{
  "kind": "collectionType",
  "collectionName": "user_goals",
  "info": {
    "singularName": "user-goal",
    "pluralName": "user-goals",
    "displayName": "User Goal"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "date": {
      "type": "datetime",
      "required": false
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "name": {
      "type": "string"
    },
    "goal": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::goal.goal"
    },
    "progress": {
      "type": "integer",
      "min": 0
    },
    "target": {
      "type": "integer",
      "min": 0
    },
    "data": {
      "type": "json"
    },
    "deleted_at": {
      "type": "datetime"
    },
    "parent_user_goal": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::user-goal.user-goal"
    },
    "category": {
      "type": "string"
    },
    "current_status": {
      "type": "enumeration",
      "enum": [
        "active",
        "paused",
        "completed",
        "archived"
      ]
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "target_date": {
      "type": "datetime"
    },
    "completed_at": {
      "type": "datetime"
    },
    "note": {
      "type": "string"
    }
  }
}
