{
  "kind": "collectionType",
  "collectionName": "user_activities",
  "info": {
    "singularName": "user-activity",
    "pluralName": "user-activities",
    "displayName": "User Activity"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "date": {
      "type": "datetime",
      "required": false
    },
    "duration": {
      "type": "integer",
      "required": false,
      "default": 0,
      "min": 0
    },
    "data": {
      "type": "json",
      "required": false
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "name": {
      "type": "string"
    },
    "activity": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::activity.activity"
    },
    "deleted_at": {
      "type": "datetime"
    },
    "schedule": {
      "type": "json"
    },
    "target": {
      "type": "json"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "habit",
        "task",
        "event",
        "metric"
      ]
    },
    "current_status": {
      "type": "enumeration",
      "enum": [
        "active",
        "paused",
        "archived"
      ]
    },
    "user_goal": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::user-goal.user-goal"
    },
    "target_value": {
      "type": "decimal"
    },
    "target_unit": {
      "type": "string"
    },
    "target_direction": {
      "type": "enumeration",
      "enum": [
        "min",
        "max",
        "exact"
      ]
    }
  }
}
