{
  "collectionName": "components_nutrition_nutrition_facts",
  "info": {
    "displayName": "Nutrition Facts",
    "description": "FDA nutrition facts mirroring the domain NutritionFacts: typed amount columns + nested servingSize + extensible additional nutrients. (ingredients/allergens live on consumable/consumable-product, not here — Consumption has facts but no ingredients.)"
  },
  "options": {},
  "attributes": {
    "calories": { "type": "decimal" },
    "totalFat": { "type": "decimal" },
    "saturatedFat": { "type": "decimal" },
    "transFat": { "type": "decimal" },
    "cholesterol": { "type": "decimal" },
    "sodium": { "type": "decimal" },
    "totalCarbohydrate": { "type": "decimal" },
    "dietaryFiber": { "type": "decimal" },
    "totalSugars": { "type": "decimal" },
    "addedSugars": { "type": "decimal" },
    "protein": { "type": "decimal" },
    "vitaminD": { "type": "decimal" },
    "calcium": { "type": "decimal" },
    "iron": { "type": "decimal" },
    "potassium": { "type": "decimal" },
    "waterMl": { "type": "decimal" },
    "servingSize": { "type": "component", "repeatable": false, "component": "nutrition.serving-size" },
    "additional": { "type": "component", "repeatable": true, "component": "nutrition.additional-nutrient" }
  }
}
