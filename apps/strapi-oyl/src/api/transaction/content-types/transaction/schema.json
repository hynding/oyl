{
  "kind": "collectionType",
  "collectionName": "transactions",
  "info": { "singularName": "transaction", "pluralName": "transactions", "displayName": "Transaction" },
  "options": { "draftAndPublish": false },
  "attributes": {
    "recordId": { "type": "string", "required": true, "unique": true },
    "occurredAt": { "type": "datetime", "required": true },
    "note": { "type": "string" },
    "amount": { "type": "component", "repeatable": false, "component": "finance.money" },
    "category": { "type": "string" },
    "direction": { "type": "enumeration", "enum": ["expense", "income"] },
    "accountId": { "type": "string" },
    "owner": { "type": "relation", "relation": "manyToOne", "target": "plugin::users-permissions.user" }
  }
}
